# OpenStack credentials env file
#
# NOTE: DO NOT quote any values in this file. The quotes will be
#       used as part of the value and cause issues.
#
# NOTE: DO NOT add 'export' to any line in this file.
#       For your shell, use: export $(grep -v '^#' ~/.openstack_creds.env | grep -v '^$' | xargs)
#       For Docker --env-file, 'export' causes a fatal error:
#         "poorly formatted environment: variable 'export OS_AUTH_URL' contains whitespaces"
#
# These are the standard OpenStack environment variable names. The oss-k8s.sh
# script reads these and maps them to the required Terraform TF_VAR_* variables
# automatically — you do not need to set TF_VAR_* values here.
#
# Usage:
#   export $(grep -v '^#' ~/.openstack_creds.env | xargs)
#   export SYSTEM=openstack
#   ./oss-k8s.sh apply setup install
#
# OR with Docker:
#   docker run --rm -it \
#     --env SYSTEM=openstack \
#     --env-file $HOME/.openstack_creds.env \
#     --volume $(pwd):/workspace \
#     viya4-iac-k8s apply setup install

# OpenStack Keystone endpoint
OS_AUTH_URL=

# OpenStack credentials
OS_USERNAME=
OS_PASSWORD=

# OpenStack project / tenant
OS_PROJECT_NAME=

# OpenStack domain that the USER account belongs to.
# This is the identity domain used to authenticate your OpenStack username.
# Common values:
#   Default       — standard OpenStack local user accounts
#   sas-ldap      — SAS LDAP/AD-integrated environments (e.g. HPOS)
#   ldap          — generic LDAP-integrated environments
# Ask your OpenStack administrator if unsure.
OS_USER_DOMAIN_NAME=Default

# OpenStack domain that the PROJECT (tenant) belongs to.
# Required for OpenStack Identity v3. Must be set alongside OS_USER_DOMAIN_NAME.
# In most environments this is the same value as OS_USER_DOMAIN_NAME.
# Common values:
#   Default       — standard OpenStack projects
#   sas-ldap      — SAS LDAP/AD-integrated environments (e.g. HPOS)
# Leaving this unset causes: "Expecting to find domain in project" (HTTP 400).
OS_PROJECT_DOMAIN_NAME=Default

# OpenStack region
OS_REGION_NAME=

# Ansible SSH credentials for the cluster nodes (VMs provisioned by Terraform).
# These are the OS-level login credentials Ansible uses to SSH into each node
# and run configuration/setup tasks — NOT your OpenStack API credentials.
#
# TF_VAR_ansible_user     — the OS username created on the VM by cloud-init.
#                           Common values:
#                             admin   — default user created by this project's
#                                       cloud-init template (OpenStack/HPOS)
#                             ubuntu  — default for Ubuntu cloud images
#                             rocky   — default for Rocky Linux cloud images
#                           Note: This is a temporary bootstrap user. Once
#                           validation is complete, a more secure/generic user
#                           should be used.
#
# TF_VAR_ansible_password — the OS password for the above user.
#                           Default value used during validation: admin
#                           Note: This is intentionally simple for initial
#                           testing only. Rotate or replace this once the
#                           deployment is confirmed working.
TF_VAR_ansible_user=admin
TF_VAR_ansible_password=admin
